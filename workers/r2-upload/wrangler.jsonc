{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cgb-poc-r2-upload",
  "account_id": "021580fad04afae747b428a8de26168c",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "poc-checklist-fotos"
    }
  ],
  "vars": {
    "ALLOWED_ORIGINS": "*"
  }
}
